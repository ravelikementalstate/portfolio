---
import Layout from "../layouts/Layout.astro";
import ProjectCard, { type Project } from "../components/ProjectCard.astro";
import laserTagBild from "/src/assets/testbild.jpg";
import random_bild from "/src/assets/testbild.jpg";

const projects: Project[] = [
	{
		year: 2025,
		name: "Laser Tag Targets",
		kind: "Self-initiated · Interactive Game System",
		description:
			"A set of modular laser tag target units built from PVC pipe and translucent baking paper. Each module contains a calibrated photoresistor that detects incoming laser hits from custom-built blasters. The diffused surface ensures reliable detection across the entire target area. Powered by a rechargeable lithium battery via USB-C. Developed as part of an interactive laser tag system for a youth camp.",
		stack: ["Electronics", "Arduino", "Photoresistor", "C++", "Upcycling", "Battery System"],
		link: "#",
		status: "completed",
		image: laserTagBild
	},
	{
		year: 2025,
		name: "Laser Tag Blasters",
		kind: "Self-initiated · Interactive Game Hardware",
		description:
			"A set of three custom-built laser tag blasters using repurposed water gun and garden hose housings. A lithium battery rechargeable via USB-C powers a laser diode when the trigger is pulled. The blasters were designed as part of an interactive laser tag system created for a youth camp, complementing separate laser target units.",
		stack: ["Electronics", "Arduino", "Laser Diode", "C++", "Upcycling", "Battery System"],
		link: "#",
		status: "completed",
		image: random_bild
	},
	{
		year: 2025,
		name: "Space Ship Systems Game",
		kind: "Self-initiated · Interactive Game",
		description:
			"An interactive reaction-based game set in a space battle scenario. Four system buttons with corresponding LEDs (maintenance, shield, weapon, energy) must be activated when their matching LED lights up. A random sequence of signals progressively speeds up, challenging the player to keep the ship operational. Powered by an Arduino Nano Every and a lithium battery rechargeable via USB-C.",
		stack: ["Electronics", "Arduino", "LEDs", "C++", "Battery System"],
		link: "#",
		status: "completed",
		image: random_bild
	},
	{
		year: 2025,
		name: "Emotional Companion Beemo",
		kind: "Self-initiated · Interactive Device",
		description:
			"An interactive emotional companion designed to guide users through different feelings. Six buttons allow selection of emotions and navigation, while an Arduino Nano Every drives a 128x128 OLED display to deliver calming, reflective prompts. The enclosure was designed in CAD and 3D printed. Powered by a lithium battery rechargeable via USB-C.",
		stack: ["Electronics", "Arduino", "OLED Display", "C++", "CAD", "3D Printing", "Battery System"],
		link: "#",
		status: "completed",
		image: random_bild
	},
	{
		year: 2024,
		name: "Magic Wand",
		kind: "Self-initiated · Prototype",
		description:
			"A handcrafted magic wand that translates motion into light. An accelerometer is read by an Arduino Nano Every to control the brightness of a 12V LED at the tip, powered by a lithium battery rechargeable via USB-C.",
		stack: ["Electronics", "Arduino", "Accelerometer", "LED", "C++", "Woodworking", "Battery System"],
		link: "#",
		status: "completed",
		image: random_bild
	},
];

const wipProjects: Project[] = [
	{
		year: 2025,
		name: "Laser Tag Targets",
		kind: "Self-initiated · Interactive Game System",
		description:
			"A set of modular laser tag target units built from PVC pipe and translucent baking paper. Each module contains a calibrated photoresistor that detects incoming laser hits from custom-built blasters. The diffused surface ensures reliable detection across the entire target area. Powered by a rechargeable lithium battery via USB-C. Developed as part of an interactive laser tag system for a youth camp.",
		stack: ["Electronics", "Arduino", "Photoresistor", "C++", "Upcycling", "Battery System"],
		link: "#",
		status: "completed",
		image: laserTagBild
	},
];

const currently = [
	{ label: "Working on", values: ["web portfolio", "Lampe"] },
];
---

<Layout>
	<section class="container flex flex-col gap-10 mx-auto px-4 md:px-6 py-16 md:py-24 mb-10">
		<h1
			class="text-primary-800 text-3xl md:text-6xl font-semibold px-4">
			Selected <span class="highlight">projects</span>.
		</h1>
		<p
			class="text-primary-800 text-2xl md:text-3xl font-semibold px-4 leading-[1.5]">
			An archive of things I've built, mostly sparked by curiosity and personal initiative.
			Many were created as gifts for friends and family, some for myself,
			and others became part of interactive programs and stories at youth camps.
			A few originated from my university studies.
		</p>
	</section>

	<section class="container mx-auto px-4 md:px-6 pb-20 md:pb-28">
		<div class="flex items-baseline justify-between mb-6 gap-4">
			<p
				class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500">
				Entries · {projects.length}
			</p>
		</div>

		<div
			class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-14 md:gap-y-20">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>

	</section>

	<!-- Currently -->
	<section
		class="container mx-auto px-4 md:px-6 py-12 md:py-20 border-t border-primary-200/70">
		<p
			class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500 mb-6">
			Work in Progress
		</p>
		<!-- <dl class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
			{
				currently.map(({ label, values }) => {
					const items = Array.isArray(values) ? values : [values];
					return (
						<div class="flex flex-col gap-1.5">
							<dt class="font-mono uppercase text-[11px] tracking-[0.2em] text-primary-400">
								{label}
							</dt>
							{items.map((item) => (
								<dd class="font-serif text-xl md:text-2xl leading-snug text-primary-900">
									{item}
								</dd>
							))}
						</div>
					);
				})
			}
		</dl> -->

		<div
			class="grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-14 md:gap-y-20">
			{wipProjects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>
</Layout>
