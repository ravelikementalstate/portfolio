---
import Layout from "../layouts/Layout.astro";

const currently = [
  { label: "Working on", value: "web portfolio" },
  { label: "Reading", value: "Erich Fromm, The Art of Loving" },
];

const recent = [
  { year: 2026, title: "Vesper Studio", kind: "Brand system" },
  { year: 2025, title: "Offline Atlas", kind: "Product · field guide" },
  { year: 2025, title: "Low & Slow", kind: "Recipe archive" },
];
---

<Layout>
  <section class="container mx-auto px-4 md:px-6 py-16 md:py-24">

    <div class="text-primary-800 text-3xl md:text-6xl font-semibold px-4">
      <p>
        Hi, I'm Tristan <br>
        An Inventor creating electronic devices from idea to working prototype.
        <br>
        Sketching, designing, building, soldering, and programming every part.
        <br>
        Feel free to <a href="/work" class="highlight">explore my work</a> and see what I'm building.
      </p>
    </div>

    </div>
  </section>

  <!-- Currently -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-20 border-t border-primary-200/70">
    <p class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500">Currently</p>
    <dl class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
      {
        currently.map(({ label, value }) => (
          <div class="flex flex-col gap-1.5">
            <dt class="font-mono uppercase text-[11px] tracking-[0.2em] text-primary-400">{label}</dt>
            <dd class="font-serif text-xl md:text-2xl leading-snug text-primary-900">{value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Recent -->

</Layout>
