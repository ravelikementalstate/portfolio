---
import Layout from "../layouts/Layout.astro";
import FogMachine from "/src/assets/Fogmachine.mp4";

const recent = [
  { year: 2026, title: "Vesper Studio", kind: "Brand system" },
  { year: 2025, title: "Offline Atlas", kind: "Product · field guide" },
  { year: 2025, title: "Low & Slow", kind: "Recipe archive" },
];
---

<Layout>
  <section class="container mx-auto px-4 md:px-6 py-16 md:py-24">

    <div class="text-primary-800 text-3xl md:text-6xl font-semibold px-4">
      <p>
        Hi, I'm Tristan <br>
        An Inventor creating electronic devices from idea to working prototype.
        <br>
        Sketching, designing, building, soldering, and programming every part.
        <br>
        Feel free to <a href="/work" class="highlight">explore my work</a> and see what I'm building.
      </p>
    </div>

    </div>
  </section>

	<!-- "Cut here" divider -->
	<div class="container mx-auto px-4 md:px-6" aria-hidden="true">
		<!-- <div class="flex items-center gap-4 text-primary-400">
			<span
				class="font-mono uppercase text-[10px] tracking-[0.22em] text-primary-500 whitespace-nowrap">
				Platzhalter für video loop
			</span>
			<div class="flex-1 border-t border-dashed border-primary-300"></div>
		</div> -->
    
    <video class="w-full h-full" width="720" height="540" autoplay="" loop="" muted="" playsinline="">
      <!-- <source src="/letter/assets/global/hero.webm" type="video/webm"> -->
      <source src={FogMachine} type="video/mp4">
    </video>
	</div>

  <!-- Recent -->

</Layout>
