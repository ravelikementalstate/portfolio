---
import Layout from "../layouts/Layout.astro";

const experience = [
  {
    period: "Mar 3 – Mar 14, 2025",
    role: "Robotics Intern",
    org: "Berger Gruppe, Wuppertal",
    notes: "Completed a two-week internship in robotics, learning to program ABB industrial robots using RobotStudio. Developed and programmed a robot to play Tic-Tac-Toe."
  },
  {
    period: "Oct 1 – Dec 31, 2024",
    role: "Student Research Assistant",
    org: "PROLAB, THGA – Technical University of Applied Sciences Georg Agricola, Bochum",
    notes: "Developed and optimized workflows for mobile data acquisition using smartphone sensors. Evaluated apps and technologies for efficient data collection, real-time transmission, and long-term storage of measurement data."
  },
];

const education = [
  {
    period: "Aug 2022 - Present",
    role: "B.Sc. Mechanical Engineering Student",
    org: "THGA – Technical University of Applied Sciences Georg Agricola, Bochum",
    notes: "Currently pursuing a degree in Mechanical Engineering."
  },
  {
    period: "2019 – 2022",
    role: "Apprenticeship as Bank Clerk",
    org: "Volksbank Sprockhövel",
    notes: "Completed vocational training and qualified as a Bank Clerk."
  },
  {
    period: "2011 – 2018",
    role: "General Higher Education Entrance Qualification (Abitur)",
    org: "Gymnasium Waldstraße, Hattingen",
    notes: "Completed secondary education with university entrance qualification."
  },
  {
    period: "2006 – 2010",
    role: "Primary School Student",
    org: "Grundschule Oberwinzerfeld, Hattingen",
    notes: "Primary education."
  },
];

const AdditionalExperience = [
  {
    period: "Present",
    role: "Scout Leader (Stammesvorstand)",
    org: "DPSG Heilig Geist, Winz-Baak",
    notes: "Volunteer leadership role involving organization, responsibility, and coordination of group activities."
  },
  {
    period: "Feb - Mar 2019",
    role: "Cultural Exchange",
    org: "Host Family, Tokyo, Japan",
    notes: "Lived with a host family, gaining cultural experience and independence."
  },
  {
    period: "Aug 2018 - Feb - 2019",
    role: "Au Pair",
    org: "Host Family, Sydney, Australia",
    notes: "Worked as an au pair, developing responsibility, adaptability, and cross-cultural communication skills."
  },
];

const skills = {
  "Engineering & Design": ["Autodesk Inventor", "CAD Design", "3D Modeling"],
  "Programming & Development": ["C++ Programming", "Arduino IDE", "RobotStudio Programming", "Visual Studio Code"],
  "Electronics & Hardware": ["Soldering", "Electronics Assembly", "Hardware Prototyping"],
  "Productivity & Documentation": ["Microsoft Excel", "Microsoft Word", "Microsoft PowerPoint"],
};
---

<Layout>
	<section class="container flex flex-col gap-10 mx-auto px-4 md:px-6 py-16 md:py-24 mb-10">
		<h1
			class="text-primary-800 text-3xl md:text-6xl font-semibold px-4">
			The one <span class="highlight">Resume</span>.
		</h1>
		<p
			class="text-primary-800 text-2xl md:text-3xl font-semibold px-4 leading-[1.5]">
			This page provides an overview of my background, education,
      and experience as an inventor and builder.
      It also serves as a toolbox of the skills, technologies, and software I use to design,
      build, and program my projects.
		</p>
	</section>

  <!-- Experience -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-16 border-t border-primary-200/70">
    <h2 class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500 mb-8">Experience</h2>
    <ol class="divide-y divide-dashed divide-primary-300/80 border-y border-dashed border-primary-300/80">
      {
        experience.map(({ period, role, org, notes }) => (
          <li class="grid grid-cols-1 md:grid-cols-[12rem_1fr] items-baseline gap-4 md:gap-10 py-8">
            <p class="font-mono text-sm text-primary-500 whitespace-nowrap">{period}</p>
            <div>
              <p class="font-bold text-2xl md:text-3xl text-primary-900">{role}</p>
              <p class="mt-1 font-bold italic text-primary-600">{org}</p>
              <p class="mt-3 max-w-2xl text-primary-700 leading-relaxed">{notes}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Education -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-16 border-t border-primary-200/70">
    <h2 class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500 mb-8">Education</h2>
    <ol class="divide-y divide-dashed divide-primary-300/80 border-y border-dashed border-primary-300/80">
      {
        education.map(({ period, role, org, notes }) => (
          <li class="grid grid-cols-1 md:grid-cols-[12rem_1fr] items-baseline gap-4 md:gap-10 py-8">
            <p class="font-mono text-sm text-primary-500 whitespace-nowrap">{period}</p>
            <div>
              <p class="font-bold text-2xl md:text-3xl text-primary-900">{role}</p>
              <p class="mt-1 font-bold italic text-primary-600">{org}</p>
              <p class="mt-3 max-w-2xl text-primary-700 leading-relaxed">{notes}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

    <!-- Additional Experience -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-16 border-t border-primary-200/70">
    <h2 class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500 mb-8">Additional Experience</h2>
    <ol class="divide-y divide-dashed divide-primary-300/80 border-y border-dashed border-primary-300/80">
      {
        AdditionalExperience.map(({ period, role, org, notes }) => (
          <li class="grid grid-cols-1 md:grid-cols-[12rem_1fr] items-baseline gap-4 md:gap-10 py-8">
            <p class="font-mono text-sm text-primary-500 whitespace-nowrap">{period}</p>
            <div>
              <p class="font-bold text-2xl md:text-3xl text-primary-900">{role}</p>
              <p class="mt-1 font-bold italic text-primary-600">{org}</p>
              <p class="mt-3 max-w-2xl text-primary-700 leading-relaxed">{notes}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Toolbox -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-24 border-t border-primary-200/70">
    <h2 class="font-mono uppercase text-sm tracking-[0.22em] text-primary-500 mb-8">Toolbox</h2>
    <dl class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-14">
      {
        Object.entries(skills).map(([category, items]) => (
          <div>
            <dt class="font-bold text-2xl text-primary-900 mb-4">{category}</dt>
            <dd>
              <ul class="flex flex-wrap gap-2">
                {items.map((skill) => (
                  <li class="font-mono uppercase text-[11px] tracking-[0.16em] text-primary-700 border border-primary-300/80 rounded-full px-3 py-1.5">
                    {skill}
                  </li>
                ))}
              </ul>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</Layout>
