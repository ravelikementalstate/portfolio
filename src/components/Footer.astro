---
const socials = [
	{
		name: "GitHub",
		url: "https://github.com/ravelikementalstate",
		handle: "@ravelikementalstate",
	},
];

const email = "hello@example.com";
const year = new Date().getFullYear();
const location = "Hattingen, DE";
---

<footer class="relative print:hidden">

	<!-- Sign-off -->
	<div class="container mx-auto px-4 md:px-6 pt-14 pb-14 md:pt-24 md:pb-20">
		<div class="border-t border-primary-200/70 bg-primary-100/40"></div>

		<div class="my-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-10">
			<div class="lg:col-span-8">
				<h2
					class="font-bold text-2xl md:text-4xl lg:text-5xl leading-[1.05] text-primary-900 max-w-[40ch]">
					<span class="text-4xl md:text-6xl lg:text-7xl">
					Interested?</span>
					<br />
					Feel free to check out my
					<a href="/resume" class="highlight italic">resume</a> or
					<a href="/contact" class="highlight italic">contact</a>
					me for more information.
				</h2>

				<p
					class="font-mono mt-8 text-primary-700 max-w-4xl text-lg leading-relaxed">
					I'm open to any kind of collaboration. <br>
					From discussing projects to building electronics, making music, or sharing a sense of humanity.
				</p>
			</div>

			<aside
				class="lg:col-span-4 lg:border-l lg:border-primary-200/80 lg:pl-10">
				<ul
					class="divide-y divide-primary-200/60 border-y border-primary-200/60">
					{
						socials.map(({ name, url, handle }) => (
							<li>
								<a
									href={url}
									target="_blank"
									rel="noopener noreferrer"
									class="group flex items-baseline justify-between gap-4 py-4 transition-colors hover:text-primary-950">
									<span class="font-mono text-xl text-primary-900 transition-transform duration-300 group-hover:translate-x-1">
										{name}
									</span>
									<span class="font-mono inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.16em] text-primary-500 transition-colors group-hover:text-accent">
										<span>{handle ?? "Visit"}</span>
										<span
											aria-hidden="true"
											class="inline-block transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
											↗
										</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>


			</aside>
		</div>
	</div>

	<!-- Colophon -->
	<div class="container px-6 mx-auto">
		<div
			class="container border-t py-5 border-primary-200/70 bg-primary-100/40
            flex flex-col md:flex-row md:items-center md:justify-between gap-3
            font-mono uppercase text-[9px] tracking-[0.22em] text-primary-500">
			<p class="flex flex-wrap items-center gap-x-2 gap-y-1">
				<span>© {year} — Tristan</span>
				<span class="text-primary-300">/</span>
				<span>{location}</span>
				<span class="text-primary-300">—</span>
				<span>code assistance</span>
				<a
					href="https://infinitel8p.com/"
					target="_blank"
					rel="noopener noreferrer"
					class="text-primary-700 hover:text-accent transition-colors
                underline decoration-primary-300 hover:decoration-accent
                underline-offset-[3px] decoration-[1.5px]
                focus-visible:outline-none focus-visible:text-accent">
					Ludo
				</a>
			</p>
			<a
				href="#top"
				data-top-btn
				class="self-start md:self-auto inline-flex items-center gap-2 text-primary-500
            hover:text-accent transition-colors
            focus-visible:outline-none focus-visible:text-accent">
				<span>Return to top</span>
				<span aria-hidden="true">↑</span>
			</a>
		</div>
	</div>
</footer>

<script is:inline>
	(function () {
		function initMail() {
			const btns = document.querySelectorAll("[data-mail-btn]");
			btns.forEach(btn => {
				if (!btn || btn.__bound) return;
				btn.__bound = true;
				btn.addEventListener("click", async () => {
					const email = btn.dataset.mail;
				if (!email) return;
				try {
					await navigator.clipboard.writeText(email);
				} catch (_) {
					/* noop */
				}
				const copyText = btn.querySelector("[data-mail-copy-text]");
				if (!copyText) return;
				const prev = copyText.textContent;
				copyText.textContent = "Copied";
				btn.setAttribute("data-copied", "true");
				clearTimeout(btn.__t);
				btn.__t = setTimeout(() => {
					copyText.textContent = prev || "Copy";
					btn.removeAttribute("data-copied");
				}, 1400);
			});
		}

		function initTop() {
			const btn = document.querySelector("[data-top-btn]");
			if (!btn || btn.__bound) return;
			btn.__bound = true;
			btn.addEventListener("click", event => {
				event.preventDefault();
				const prefersReduced = window.matchMedia(
					"(prefers-reduced-motion: reduce)",
				).matches;
				window.scrollTo({
					top: 0,
					behavior: prefersReduced ? "auto" : "smooth",
				});
			});
		}

		function boot() {
			initMail();
			initTop();
		}

		document.addEventListener("astro:page-load", boot);
		if (document.readyState === "loading")
			document.addEventListener("DOMContentLoaded", boot);
		else boot();
	})();
</script>
