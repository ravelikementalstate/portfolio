---
export type Project = {
  name: string;
  year: number;
  kind: string;
  description: string;
  stack: string[];
  link: string;
  image?: string;
  status?: "shipped" | "in progress" | "archived";
};

type Props = { project: Project; class?: string };
const { project, class: extraClass = "" } = Astro.props;
const { name, year, kind, description, stack, link, image, status = "shipped" } = project;
const external = link.startsWith("http");
---

<a
  href={link}
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
  class:list={[
    "group flex flex-col gap-5 no-underline text-inherit",
    extraClass,
  ]}
>
  <div class="relative aspect-16/10 overflow-hidden border border-primary-300 bg-primary-200/40 transition-colors duration-500 group-hover:border-primary-500">
    {image ? (
      <img
        src={image}
        alt={`${name} preview`}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]"
      />
    ) : (
      <div
        aria-hidden="true"
        class="w-full h-full project-card__placeholder"
      />
    )}
  </div>

  <div class="flex items-baseline gap-3 font-mono uppercase text-[11px] tracking-[0.22em] text-primary-500">
    <span>{year}</span>
    <span aria-hidden="true" class="flex-1 border-b border-dashed border-primary-300/80"></span>
    <span class:list={["text-primary-400", status === "in progress" && "text-accent"]}>
      {status}
    </span>
  </div>

  <div class="min-w-0">
    <h3 class="font-serif text-3xl md:text-4xl leading-[1.05] text-primary-900 transition-transform duration-300 group-hover:translate-x-1">
      {name}
    </h3>
    <p class="mt-2 font-serif italic text-lg text-primary-500">{kind}</p>
  </div>

  <p class="max-w-[52ch] text-primary-700 leading-relaxed">{description}</p>

  <p class="font-mono uppercase text-[10px] tracking-[0.2em] text-primary-600">
    {stack.join(" · ")}
  </p>
</a>

<style>
  .project-card__placeholder {
    background-image: repeating-linear-gradient(
      45deg,
      color-mix(in oklab, var(--color-primary-400) 35%, transparent) 0 1px,
      transparent 1px 14px
    );
  }
</style>
