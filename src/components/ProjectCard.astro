---
export type Project = {
  name: string;
  year: number;
  kind: string;
  description: string;
  stack: string[];
  link: string;
  image?: string;
  status?: "shipped" | "in progress" | "archived";
};

type Props = { project: Project; class?: string };
const { project,  class: extraClass = "" } = Astro.props;
const {
  name,
  year,
  kind,
  description,
  stack,
  link,
  image,
  status = "shipped",
} = project;
---

<a class:list={["project-card", extraClass]} href={link} target={link.startsWith("http") ? "_blank" : undefined} rel={link.startsWith("http") ? "noreferrer" : undefined}>
  <div class="project-card__plate">
    <span class="project-card__plate-mark" aria-hidden="true">{year}</span>
    <div class="project-card__frame">
      {image ? (
        <img
          class="project-card__image"
          src={image}
          alt={`${name} - preview`}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="project-card__image project-card__image--placeholder" aria-hidden="true"></div>
      )}
    </div>
  </div>

  <h3 class="project-card__title">{name}</h3>
  <p class="project-card__kind">{kind}</p>

  <p class="project-card__description">{description}</p>

  <div class="project-card__stack" aria-label="Stack">
    {stack.map((s) => <span class="project-card__chip">{s}</span>)}
  </div>

  <div class="project-card__footer">
    <span class="project-card__status" data-status={status}>
      {status}
    </span>
    <span class="project-card__cta">
      Open
      <span aria-hidden="true" class="project-card__arrow">↗</span>
    </span>
  </div>
</a>

<style>
  .project-card {
    --tick-size: 10px;
    position: relative;
    display: grid;
    grid-template-rows: auto auto auto 1fr auto auto;
    gap: 0.7rem;
    padding: 1rem 1rem 1.2rem;
    background: color-mix(in oklab, var(--color-primary-50) 88%, transparent);
    border: 1px solid var(--color-primary-300);
    text-decoration: none;
    color: inherit;
    isolation: isolate;
    transition:
      transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 0.35s ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
  }

  /* corner ticks */
  .project-card::before,
  .project-card::after {
    content: '';
    position: absolute;
    width: var(--tick-size);
    height: var(--tick-size);
    border: 1px solid var(--color-primary-900);
    opacity: 0.65;
    pointer-events: none;
  }
  .project-card::before {
    top: -1px;
    left: -1px;
    border-right: none;
    border-bottom: none;
  }
  .project-card::after {
    bottom: -1px;
    right: -1px;
    border-left: none;
    border-top: none;
  }

  .project-card__plate {
    position: relative;
    margin: 0 0 0.8rem;
  }

  .project-card__plate-mark {
    position: absolute;
    top: -6px;
    left: -6px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    padding: 0.2rem 0.45rem;
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-900);
    color: var(--color-primary-900);
    transform-origin: top left;
    transition:
      transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .project-card:hover .project-card__plate-mark {
    transform: rotate(-2.4deg) translate(-1px, -1px);
    box-shadow: 1px 2px 0 color-mix(in oklab, var(--color-primary-900) 22%, transparent);
  }

  .project-card__frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background: color-mix(in oklab, var(--color-primary-200) 55%, transparent);
    border: 1px solid var(--color-primary-300);
    overflow: hidden;
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .project-card__image--placeholder {
    background:
      repeating-linear-gradient(
        45deg,
        color-mix(in oklab, var(--color-primary-300) 55%, transparent) 0 1px,
        transparent 1px 12px
      ),
      color-mix(in oklab, var(--color-primary-200) 60%, transparent);
  }

  .project-card:hover .project-card__image {
    transform: scale(1.03);
  }

  .project-card__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    line-height: 1.08;
    color: var(--color-primary-900);
    margin: 0.15rem 0 0;
  }

  .project-card__kind {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.98rem;
    color: var(--color-primary-600);
    margin: -0.25rem 0 0;
  }

  .project-card__description {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-primary-700);
    margin: 0;
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .project-card__chip {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-primary-300);
    color: var(--color-primary-600);
    border-radius: 2px;
    background: color-mix(in oklab, var(--color-primary-100) 70%, transparent);
    transition:
      border-color 0.4s ease,
      color 0.4s ease;
  }
  .project-card:hover .project-card__chip {
    border-color: color-mix(in oklab, var(--color-primary-900) 45%, var(--color-primary-300));
    color: var(--color-primary-800);
  }

  .project-card__footer {
    margin-top: 0.9rem;
    padding-top: 0.85rem;
    border-top: 1px dashed var(--color-primary-300);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card__status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary-600);
  }

  .project-card__cta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary-800);
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
  }
  .project-card:hover .project-card__cta { color: var(--color-accent); }

  .project-card__arrow {
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .project-card:hover .project-card__arrow {
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card__arrow,
    .project-card__image,
    .project-card__plate-mark,
    .project-card__chip {
      animation: none;
      transition: none;
    }
    .project-card:hover .project-card__plate-mark { transform: none; }
  }
</style>
