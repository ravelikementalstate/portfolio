---
const links = [
	{ url: "/", name: "Home", hideOnMobile: true },
	{ url: "/work", name: "Work" },
	{ url: "/resume", name: "Résumé" },
	{ url: "/contact", name: "Contact" },
];

function normalize(path: string) {
	const base = import.meta.env.BASE_URL.replace(/\/$/, "");
	const stripped =
		base && path.startsWith(base) ? path.slice(base.length) : path;
	return "/" + stripped.replace(/^\/|\/$/g, "");
}

function isActive(href: string) {
	const here = normalize(new URL(Astro.url).pathname);
	const target = normalize(href);
	if (target === "/") return here === "/";
	return here === target || here.startsWith(target + "/");
}
---

<nav
	class="relative z-50 print:hidden mx-auto container px-4 md:px-6
         grid grid-cols-[1fr_auto_1fr] items-center gap-4
         border-b border-primary-200/70"
	style="height: var(--navbar-height)">
	<!-- Seal / Monogram -->
	<a
		href="/"
		aria-label="Home"
		class="group relative justify-self-start shrink-0 inline-flex items-center gap-3 focus-visible:outline-none">

		<span class="hidden sm:flex flex-col leading-none">
			<span
				class="font-serif text-[2rem] tracking-tight text-primary-900">
				tristan.h
			</span>
			<span
				class="font-mono uppercase text-[0.95rem] tracking-[0.18em] text-primary-500 mt-0.5">
				maker & inventor
			</span>
		</span>
	</a>

	<!-- Pill nav -->
	<div
		class="relative max-w-full overflow-x-auto no-scrollbar"
		data-nav-container>
		<div
			id="nav-indicator"
			class="absolute left-0 top-0 z-0 bg-transparent nav-corners
             transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]
             opacity-0 pointer-events-none"
			style="--corner-size: 10px; --corner-thickness: 0.8px;"
			transition:persist>
		</div>
		<ul class="relative flex items-center justify-center gap-4 px-2">
			{
				links.map(({ url, name, hideOnMobile }) => {
					const active = isActive(url);
					return (
						<li class={hideOnMobile ? "hidden md:block" : ""}>
							<a
								href={url}
								data-nav-link
								data-active={active ? "true" : "false"}
								class:list={[
									"relative z-10 block whitespace-nowrap rounded-full",
									"px-4 md:px-5 py-2.5 text-[0.92rem]",
									"transition-colors duration-1000",
									"focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70",
									active ? "text-accent/70" : "text-primary-800 hover:text-accent/60",
								]}>
								{name}
							</a>
						</li>
					);
				})
			}
		</ul>
	</div>

	<button
			type="button"
			data-theme-toggle
			aria-label="Toggle color theme"
			class="absolute right-6 top-1/2 -translate-y-1/2 grid place-items-center size-10 rounded-full
             bg-primary-100 text-primary-800 border border-primary-300
             hover:bg-primary-300/70 active:scale-90
             transition-[right] duration-300
             focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70">
				<svg
					class="size-4.5 transition-transform duration-500"
					data-theme-icon
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true">
					<!-- Sun (light mode) -->
					<g data-sun>
						<circle cx="12" cy="12" r="4.25"></circle>
						<path
							d="M12 3v1.8M12 19.2V21M3 12h1.8M19.2 12H21M5.3 5.3l1.3 1.3M17.4 17.4l1.3 1.3M5.3 18.7l1.3-1.3M17.4 6.6l1.3-1.3"
						></path>
					</g>
					<!-- Moon (dark mode) -->
					<path
						data-moon
						d="M20 14.5A8 8 0 0 1 9.5 4a0.5 0.5 0 0 0-.7-.5A9 9 0 1 0 20.5 15.2a0.5 0.5 0 0 0-.5-.7Z"
						class="hidden"></path>
				</svg>
			</button>

</nav>

<script>
	import "../javascript/navbar.js";
</script>

<style>
	@import "../styles/navbar.css";
</style>
